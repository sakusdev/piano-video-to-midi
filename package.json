{
  "name": "piano-video-to-midi",
  "version": "0.1.2",
  "description": "Convert Synthesia-style piano videos to MIDI in the browser and Electron.",
  "author": "sakusdev",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "electron:preview": "npm run build && electron .",
    "build:electron": "npm run build && electron-builder --publish never",
    "sync:android": "npm run build && cap sync android",
    "build:android": "npm run sync:android && cd android && gradlew assembleDebug"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.3",
    "@capacitor/core": "^8.3.3",
    "@vitejs/plugin-react": "5.1.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "typescript": "5.9.3",
    "vite": "7.3.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "dev.sakus.piano-video-to-midi",
    "productName": "Piano Video to MIDI",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "zip"
      ]
    }
  }
}
